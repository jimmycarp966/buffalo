{
  "name": "buffalo-pos",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "dev:clean": "rm -rf .next && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "next typegen && tsc --noEmit",
    "clean": "rm -rf .next node_modules/.cache",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:security": "jest tests/security",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:performance": "jest tests/performance",
    "test:accessibility": "jest tests/accessibility",
    "test:responsive": "jest tests/responsive",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:security && npm run test:e2e",
    "test:ci": "npm run lint && npm run type-check && npm run test:all",
    "test:dashboard": "node tests/test-dashboard.js",
    "test:flow": "jest tests/integration/flows",
    "test:edge": "jest tests/integration/edge-cases",
    "playwright:install": "playwright install",
    "setup:database": "node scripts/create-missing-tables.js",
    "performance:test": "node scripts/performance-test.js",
    "performance:lighthouse": "node scripts/performance-test.js --lighthouse",
    "vercel-build": "next build",
    "build:clean": "if exist .next rmdir /s /q .next && next build",
    "deploy:clean": "npm run build:clean"
