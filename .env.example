# ============================================================
#  Variables de entorno — copiá este archivo como .env.local
#  y completá con los datos de TU proyecto.
#      cp .env.example .env.local
# ============================================================

# ===== Supabase (REQUERIDO) =====
# Project Settings -> API en https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# ===== AFIP / Facturación electrónica (OPCIONAL) =====
# Solo si vas a emitir facturas AFIP. Dejalo comentado para arrancar sin facturación.
# AFIP_CERT_PEM=
# AFIP_KEY_PEM=
# AFIP_ACCESS_TOKEN=
